# ---------------------------------------------------------------------------
# Cost Function
# Metric: cost per watt of cooling capacity ($/W) = TAC / Q_design
#
# CAPEX: core aluminium volume + fin sheet area, annualised over 3 seasons
#   - Al raw material price ~$2.5/kg (LME spot 2024)
#   - Fin sheet fabrication ~$0.8/m2 of fin area (estimated for thin-rolled Al)
# OPEX: fan + pump electrical energy per season
#   - Electricity cost ~$0.15/kWh (university team estimate)
#   - 200 operating hours/season (testing + events)
#   - Pressure drops via Darcy-Weisbach
# ---------------------------------------------------------------------------

rho_Al = 2700 # density of aluminium (kg/m3)
C_Al_per_kg = 2.5 # Al raw material cost ($/kg)
C_fin_per_m2 = 0.8 # fin sheet fabrication cost ($/m2 of fin area)
N_years = 3 # amortisation period (racing seasons)
discount_rate = 0.08 # 8% annual discount rate
CRF = (discount_rate*(1+discount_rate)**N_years)/((1+discount_rate)**N_years-1)
C_elec = 0.15 # electricity cost ($/kWh)
op_hours = 200 # fan/pump operating hours per season
eta_fan = 0.55 # fan total efficiency
eta_pump = 0.60 # pump hydraulic efficiency

fin_gap = tube_pitch-a_tube # 8mm fin channel height
D_h_air_fin = 2*fin_gap # approx hydraulic diameter of fin channel
Re_fin = rho_air*v_air*D_h_air_fin/mu_air
f_air_fin = 64/Re_fin # laminar friction factor (Re_fin < 500 here)

def radiator_cost_per_watt(sigma, A_face, H_val=H_dp, mdot_val=mdot_dp):
    # returns (cost_per_watt $/W, Q W, capex_ann $/yr, opex_ann $/yr)
    Q_W = compute_Q(sigma, A_face, H_val, mdot_val)
    if Q_W <= 0:
        return np.inf, 0, np.inf, np.inf
    W_val = A_face/H_val
    V_core = A_face*d
    A_fin_tot = sigma*A_face*d
    # CAPEX
    capex_raw = rho_Al*C_Al_per_kg*V_core+C_fin_per_m2*A_fin_tot
    capex_ann = capex_raw*CRF
    # OPEX: fan
    dp_air = f_air_fin*(d/D_h_air_fin)*0.5*rho_air*v_air**2
    Q_vol_air = v_air*A_face
    P_fan = dp_air*Q_vol_air/eta_fan
    # OPEX: pump
    n_t = max(1, int(np.floor(H_val/tube_pitch)))
    mdot_t = mdot_val/n_t
    v_w = mdot_t/(rho_water*A_tube)
    Re_w = rho_water*v_w*D_h/mu_water
    f_w = 0.316*Re_w**(-0.25) # Blasius friction factor (turbulent)
    dp_water = f_w*(W_val/D_h)*0.5*rho_water*v_w**2
    Q_vol_wat = mdot_val/rho_water
    P_pump = dp_water*Q_vol_wat/eta_pump
    opex_ann = (P_fan+P_pump)/1000*op_hours*C_elec
    tac = capex_ann+opex_ann
    return tac/Q_W, Q_W, capex_ann, opex_ann

cpw_base, Q_base, capex_base, opex_base = radiator_cost_per_watt(sigma_dp, A_face_dp)
print(f'\nWeek 6: Cost breakdown at baseline (sigma={sigma_dp}, A_face={A_face_dp:.4f} m^2):')
