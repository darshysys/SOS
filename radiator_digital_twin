print(f'  CAPEX (ann.)     = ${capex_base:.4f}/yr')
print(f'  OPEX             = ${opex_base:.4f}/yr')
print(f'  TAC              = ${capex_base+opex_base:.4f}/yr')
print(f'  Cost per watt    = ${cpw_base:.6f}/W')

# Gradient descent on Rosenbrock test function
# f(x,y) = (1-x)^2 + 100*(y-x^2)^2, global min at (1,1)
# df/dx = -2(1-x) - 400x(y-x^2), df/dy = 200(y-x^2)
def rosenbrock(x, y):
    return (1-x)**2+100*(y-x**2)**2

def rosenbrock_grad(x, y):
    dfdx = -2*(1-x)-400*x*(y-x**2)
    dfdy = 200*(y-x**2)
    return np.array([dfdx, dfdy])

def gradient_descent(grad_fn, x0, learning_rate=0.001, max_iter=50000, tol=1e-8):
    xy = np.array(x0, dtype=float)
    history = [xy.copy()]
    for i in range(max_iter):
        g = grad_fn(xy[0], xy[1])
        xy_new = xy-learning_rate*g
        history.append(xy_new.copy())
        if np.linalg.norm(xy_new-xy) < tol:
            print(f'  Rosenbrock GD converged after {i+1} iterations.')
            break
        xy = xy_new
    return xy, np.array(history)

x0_rb = [-1.0, 1.0]
