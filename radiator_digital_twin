from scipy.optimize import minimize

def objective(x):
    cpw_x, _, _, _ = radiator_cost_per_watt(x[0], x[1])
    return cpw_x

def Q_constraint(x):
    return compute_Q(x[0], x[1], H_dp, mdot_dp)-5500 # must be >= 0

bounds = [(500, 3000), (0.05, 0.40)]
