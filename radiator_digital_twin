    cs = ax_tmp.contour(sigma_range, A_face_range, Q_predicted, levels=[level])
    plt.close(fig_tmp)

    # Gather all vertices from all paths at this level (mirrors MATLAB's
    # contourc, which can return multiple segments for one level)
    sigma_pts = []
    A_face_pts = []
    for segment in cs.allsegs[0]:
        sigma_pts.extend(segment[:, 0])
        A_face_pts.extend(segment[:, 1])

    return np.array(sigma_pts), np.array(A_face_pts)


