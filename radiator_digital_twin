def compute_Q(sigma, A_face, H_val, mdot_val):
    # computes steady-state Q (W) - same physics as the main sweep
    n_t = int(np.floor(H_val/tube_pitch))
    if n_t == 0:
        return 0
    Re_a = (rho_air*v_air*d)/mu_air
    Nu_a = 0.664*Re_a**0.5*Pr_air**(1/3)
    h_a = Nu_a*k_air/d
    mdot_t = mdot_val/n_t
    v_w = mdot_t/(rho_water*A_tube)
    Re_w = (rho_water*v_w*D_h)/mu_water
    Nu_w = 0.023*Re_w**0.8*Pr_water**0.4
    h_w = Nu_w*k_water/D_h
    U_val = 1/((1/h_a)+(1/h_w))
    C_a = rho_air*v_air*cp_air*A_face
    C_w = mdot_val*cp_water
    C_mn = min(C_a, C_w)
    C_mx = max(C_a, C_w)
    C_st = C_mn/C_mx
    A_fins_val = sigma*A_face*d
    NTU_val = U_val*A_fins_val/C_mn
    eps = 1-np.exp((NTU_val**0.22/C_st)*(np.exp(-C_st*NTU_val**0.78)-1))
    return eps*C_mn*(T_coolant_in-T_air_in)

