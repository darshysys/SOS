# method 1: projected gradient descent with numerical gradients + backtracking line search
def numerical_gradient(f, x, h=1e-4):
    grad = np.zeros_like(x)
    for k in range(len(x)):
        x_fwd = x.copy(); x_fwd[k] += h
        x_bwd = x.copy(); x_bwd[k] -= h
        grad[k] = (f(x_fwd)-f(x_bwd))/(2*h)
    return grad

def projected_gradient_descent(f, x0, bounds_list, lr=1e-4, max_iter=8000, tol=1e-9):
    # box projection + quadratic penalty for Q >= 5500W constraint
    x = np.array(x0, dtype=float)
    lo = np.array([b[0] for b in bounds_list], dtype=float)
    hi = np.array([b[1] for b in bounds_list], dtype=float)
    penalty_weight = 5e4
    def penalised(xv):
        violation = max(0, 5500-compute_Q(xv[0], xv[1], H_dp, mdot_dp))
        return f(xv)+penalty_weight*violation**2
    hist = [x.copy()]
    f_cur = penalised(x)
    step = lr
    for i in range(max_iter):
        g = numerical_gradient(penalised, x)
        for _ in range(30): # backtracking line search
            x_cand = np.clip(x-step*g, lo, hi)
            f_cand = penalised(x_cand)
            if f_cand <= f_cur:
                break
            step*= 0.5
        x_new = x_cand
        hist.append(x_new.copy())
        if np.linalg.norm(x_new-x) < tol:
            print(f'  GD converged after {i+1} iterations.')
            break
        x = x_new
        f_cur = f_cand
        step = min(step*1.05, lr)
    else:
        print(f'  GD reached max iterations ({max_iter}).')
    return x, np.array(hist)

